#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

output_dir="$ROOT/assets/marketing"
screenshot_root="$ROOT/assets/screenshots/variants"
background="$ROOT/assets/marketing/readme-hero-background.jpg"
jpeg_quality="0.88"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/assemble-readme-marketing-heroes [--output-dir <path>]
                                             [--screenshot-root <path>]
                                             [--background <path|none>]
                                             [--jpeg-quality <0.0-1.0>]

Builds the bilingual public README marketing hero images from current
Tokenmon screenshots. The product UI always comes from real screenshot files.
The optional background is decorative only; use --background none for the
deterministic fallback backdrop.
EOF
}

abspath() {
  local path="$1"
  if [[ "$path" == /* ]]; then
    printf '%s\n' "$path"
  else
    printf '%s/%s\n' "$ROOT" "$path"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --output-dir)
      shift
      output_dir="$(abspath "${1:-}")"
      ;;
    --screenshot-root)
      shift
      screenshot_root="$(abspath "${1:-}")"
      ;;
    --background)
      shift
      if [[ "${1:-}" == "none" ]]; then
        background=""
      else
        background="$(abspath "${1:-}")"
      fi
      ;;
    --jpeg-quality)
      shift
      jpeg_quality="${1:-}"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unsupported argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift || true
done

mkdir -p "$output_dir"

if [[ -n "$background" && ! -f "$background" ]]; then
  printf 'README hero background not found, using fallback backdrop: %s\n' "$background" >&2
  background=""
fi

swift - "$output_dir" "$screenshot_root" "$background" "$jpeg_quality" <<'SWIFT'
import AppKit
import Foundation

let args = CommandLine.arguments
let outputDir = args[1]
let screenshotRoot = args[2]
let backgroundPath = args[3]
let jpegQuality = CGFloat(Double(args[4]) ?? 0.88)

struct Sources {
    let menu: NSImage
    let raid: NSImage
    let reward: NSImage
    let dex: NSImage
}

func load(_ path: String) -> NSImage {
    guard let image = NSImage(contentsOfFile: path) else {
        fputs("Missing image: \(path)\n", stderr)
        exit(1)
    }
    return image
}

func sources(language: String) -> Sources {
    let base = "\(screenshotRoot)/\(language)/dark"
    return Sources(
        menu: load("\(base)/menu-overview.png"),
        raid: load("\(base)/raid-tab.png"),
        reward: load("\(base)/reward-archive.png"),
        dex: load("\(base)/seen-dex.png")
    )
}

let background = backgroundPath.isEmpty ? nil : NSImage(contentsOfFile: backgroundPath)
let english = sources(language: "english")
let korean = sources(language: "korean")

func color(_ hex: UInt32, _ alpha: CGFloat = 1) -> NSColor {
    NSColor(
        calibratedRed: CGFloat((hex >> 16) & 255) / 255,
        green: CGFloat((hex >> 8) & 255) / 255,
        blue: CGFloat(hex & 255) / 255,
        alpha: alpha
    )
}

final class Renderer {
    let width: CGFloat
    let height: CGFloat
    let rep: NSBitmapImageRep

    init(width: CGFloat = 1920, height: CGFloat = 1080) {
        self.width = width
        self.height = height
        guard let bitmap = NSBitmapImageRep(
            bitmapDataPlanes: nil,
            pixelsWide: Int(width),
            pixelsHigh: Int(height),
            bitsPerSample: 8,
            samplesPerPixel: 4,
            hasAlpha: true,
            isPlanar: false,
            colorSpaceName: .deviceRGB,
            bytesPerRow: 0,
            bitsPerPixel: 0
        ) else {
            fputs("Could not create bitmap\n", stderr)
            exit(1)
        }
        bitmap.size = NSSize(width: width, height: height)
        self.rep = bitmap
        guard let context = NSGraphicsContext(bitmapImageRep: bitmap) else {
            fputs("Could not create graphics context\n", stderr)
            exit(1)
        }
        NSGraphicsContext.current = context
        context.imageInterpolation = .high
        context.shouldAntialias = true
    }

    func rect(_ x: CGFloat, _ y: CGFloat, _ w: CGFloat, _ h: CGFloat) -> CGRect {
        CGRect(x: x, y: height - y - h, width: w, height: h)
    }

    func fill(_ nsColor: NSColor, _ x: CGFloat, _ y: CGFloat, _ w: CGFloat, _ h: CGFloat) {
        nsColor.setFill()
        rect(x, y, w, h).fill()
    }

    func rounded(_ x: CGFloat, _ y: CGFloat, _ w: CGFloat, _ h: CGFloat, radius: CGFloat, fill: NSColor, stroke: NSColor? = nil) {
        let path = NSBezierPath(roundedRect: rect(x, y, w, h), xRadius: radius, yRadius: radius)
        fill.setFill()
        path.fill()
        if let stroke {
            stroke.setStroke()
            path.lineWidth = 1
            path.stroke()
        }
    }

    func drawBackground(_ image: NSImage?) {
        fill(color(0x070a10), 0, 0, width, height)
        let target = rect(0, 0, width, height)

        if let image {
            let sourceSize = image.size
            let sourceAspect = sourceSize.width / max(sourceSize.height, 1)
            let targetAspect = width / height
            var source = CGRect(origin: .zero, size: sourceSize)
            if sourceAspect > targetAspect {
                let newWidth = sourceSize.height * targetAspect
                source.origin.x = (sourceSize.width - newWidth) / 2
                source.size.width = newWidth
            } else {
                let newHeight = sourceSize.width / targetAspect
                source.origin.y = (sourceSize.height - newHeight) / 2
                source.size.height = newHeight
            }
            image.draw(in: target, from: source, operation: .copy, fraction: 1, respectFlipped: false, hints: nil)
        } else {
            NSGradient(colors: [color(0x060a12), color(0x111b24), color(0x07110f)])?.draw(in: target, angle: 0)
            rounded(90, 92, 410, 260, radius: 32, fill: color(0xf0b64d, 0.06), stroke: color(0xf0b64d, 0.10))
            rounded(260, 705, 420, 220, radius: 34, fill: color(0x5ab184, 0.05), stroke: color(0x5ab184, 0.10))
            rounded(1450, 82, 360, 230, radius: 34, fill: color(0x66a4ff, 0.05), stroke: color(0x66a4ff, 0.10))
        }

        fill(NSColor.black.withAlphaComponent(0.42), 0, 0, width, height)
        NSGradient(colors: [
            NSColor.black.withAlphaComponent(0.74),
            NSColor.black.withAlphaComponent(0.18),
            NSColor.black.withAlphaComponent(0.42)
        ])?.draw(in: target, angle: 0)
    }

    func text(_ string: String, _ x: CGFloat, _ y: CGFloat, _ w: CGFloat, _ h: CGFloat, _ size: CGFloat, _ weight: NSFont.Weight, _ nsColor: NSColor, line: CGFloat? = nil) {
        let paragraph = NSMutableParagraphStyle()
        paragraph.alignment = .left
        paragraph.lineBreakMode = .byWordWrapping
        if let line {
            paragraph.minimumLineHeight = line
            paragraph.maximumLineHeight = line
        }
        NSString(string: string).draw(
            with: rect(x, y, w, h),
            options: [.usesLineFragmentOrigin, .usesFontLeading],
            attributes: [
                .font: NSFont.systemFont(ofSize: size, weight: weight),
                .foregroundColor: nsColor,
                .paragraphStyle: paragraph,
                .kern: 0
            ]
        )
    }

    func brand(_ x: CGFloat, _ y: CGFloat) {
        rounded(x, y, 178, 42, radius: 21, fill: color(0x0f1824, 0.72), stroke: color(0x8fbaff, 0.30))
        text("Tokenmon", x + 24, y + 8, 140, 24, 21, .bold, color(0xe9f2ff))
    }

    @discardableResult
    func screenshot(_ image: NSImage, _ x: CGFloat, _ y: CGFloat, _ w: CGFloat, radius: CGFloat = 20) -> CGFloat {
        let h = w / (image.size.width / max(image.size.height, 1))
        let outer = rect(x, y, w, h)
        let path = NSBezierPath(roundedRect: outer, xRadius: radius, yRadius: radius)
        let shadow = NSShadow()
        shadow.shadowColor = NSColor.black.withAlphaComponent(0.52)
        shadow.shadowOffset = NSSize(width: 0, height: -18)
        shadow.shadowBlurRadius = 30

        NSGraphicsContext.saveGraphicsState()
        shadow.set()
        color(0x0b1018, 0.96).setFill()
        path.fill()
        NSGraphicsContext.restoreGraphicsState()

        NSGraphicsContext.saveGraphicsState()
        path.addClip()
        image.draw(in: outer, from: CGRect(origin: .zero, size: image.size), operation: .copy, fraction: 1, respectFlipped: false, hints: nil)
        NSGraphicsContext.restoreGraphicsState()

        color(0xffffff, 0.18).setStroke()
        path.lineWidth = 1
        path.stroke()
        return h
    }

    func saveJPEG(_ path: String, quality: CGFloat) {
        guard let data = rep.representation(using: .jpeg, properties: [.compressionFactor: quality]) else {
            fputs("Could not encode JPEG: \(path)\n", stderr)
            exit(1)
        }
        do {
            try data.write(to: URL(fileURLWithPath: path))
        } catch {
            fputs("Could not write \(path): \(error)\n", stderr)
            exit(1)
        }
        NSGraphicsContext.current = nil
    }
}

func homepage(path: String, sources: Sources, title: String, subtitle: String, bullets: [String], footer: String) {
    let r = Renderer()
    r.drawBackground(background)
    r.brand(88, 70)
    r.text(title, 88, 146, 750, 145, 58, .heavy, color(0xffffff), line: 68)
    r.text(subtitle, 90, 330, 730, 122, 28, .medium, color(0xd9e5f3), line: 39)
    var y: CGFloat = 492
    for bullet in bullets {
        r.rounded(90, y, 24, 24, radius: 12, fill: color(0xffcf69, 0.92))
        r.text(bullet, 132, y - 2, 660, 34, 25, .semibold, color(0xf7fbff), line: 32)
        y += 54
    }
    r.text(footer, 90, 870, 760, 82, 22, .semibold, color(0xb7c7d9), line: 31)
    r.screenshot(sources.dex, 1035, 88, 760, radius: 22)
    r.screenshot(sources.raid, 850, 332, 345)
    r.screenshot(sources.reward, 1080, 590, 720, radius: 22)
    r.saveJPEG(path, quality: jpegQuality)
}

homepage(
    path: "\(outputDir)/readme-hero-en.jpg",
    sources: english,
    title: "Local-first macOS\nAI coding companion",
    subtitle: "Use supported AI coding tools as usual. Tokenmon turns local usage into passive encounters, Dex progress, Raid, and Reward Archive.",
    bullets: [
        "No account required for P0",
        "Gameplay and collection state stay local",
        "Prompt and response text are not stored for gameplay"
    ],
    footer: "Native macOS menu bar companion. Local-first, offline-first, and built around a low-attention collection loop."
)

homepage(
    path: "\(outputDir)/readme-hero-ko.jpg",
    sources: korean,
    title: "AI 코딩을 위한\n로컬 우선 macOS 앱",
    subtitle: "평소처럼 지원되는 AI 코딩 도구를 쓰면 사용량이 조우, Dex 진행, Raid, Reward Archive로 이어집니다.",
    bullets: [
        "P0는 계정 없이 동작",
        "게임 상태는 로컬에 저장",
        "게임플레이용 프롬프트와 응답 텍스트를 저장하지 않음"
    ],
    footer: "네이티브 macOS 메뉴 막대 앱. 로컬 우선, 오프라인 우선, 낮은 주의 비용의 수집 루프."
)

print("readme_hero_en=\(outputDir)/readme-hero-en.jpg")
print("readme_hero_ko=\(outputDir)/readme-hero-ko.jpg")
print("screenshot_root=\(screenshotRoot)")
if backgroundPath.isEmpty {
    print("readme_hero_background=fallback")
} else {
    print("readme_hero_background=\(backgroundPath)")
}
SWIFT
